@TEST-DOC: Test parsing behavior of TPKT.

@TEST-EXEC: spicyc ${DIST}/analyzer/tpkt.spicy -j -d -o tpkt.hlto

@TEST-EXEC: printf '\003\000\000\004' | spicy-dump tpkt.hlto > empty
@TEST-EXEC: btest-diff empty

@TEST-EXEC: printf '\003\000\000\010TEST' | spicy-dump tpkt.hlto > one-pdu
@TEST-EXEC: btest-diff one-pdu

@TEST-EXEC: printf '\003\000\000\011TEST1\003\000\000\011TEST2' | spicy-dump tpkt.hlto > two-pdus
@TEST-EXEC: btest-diff two-pdus

@TEST-EXEC: printf 'XXXXXXXX\003\000\000\010TEST' | spicy-dump tpkt.hlto 2>&1 >sync-test
@TEST-EXEC: btest-diff sync-test

@TEST-EXEC: ! (printf '\000\000\000\004' | spicy-dump tpkt.hlto 2>&1)

@TEST-EXEC: ! (printf 'XXXXXXXX' | spicy-dump tpkt.hlto 2>&1)

