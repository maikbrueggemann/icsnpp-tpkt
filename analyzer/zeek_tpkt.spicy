module tpkt_Zeek;

import tpkt;
import zeek;
import spicy;

public function is_cotp_available(): bool &cxxname="is_cotp_available";

on tpkt::Pdus::%init {
    if(is_cotp_available())
        zeek::protocol_begin("COTP");
}

on tpkt::Pdu::%done {
    if(is_cotp_available())
        zeek::protocol_data_in(zeek::is_orig(), self.payload, spicy::Protocol::UDP);
}

on tpkt::Pdus::%done {
    if(is_cotp_available())
        zeek::protocol_end();
}
